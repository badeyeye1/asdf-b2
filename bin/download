#!/usr/bin/env bash

set -euo pipefail

# shellcheck source=../lib/utils.bash
source "$(dirname "$0")/../lib/utils.bash"

# asdf provides:
#   ASDF_INSTALL_TYPE     — "version" or "ref"
#   ASDF_INSTALL_VERSION  — the version string (no leading v)
#   ASDF_DOWNLOAD_PATH    — directory to write the artifact into

if [[ "${ASDF_INSTALL_TYPE}" != "version" ]]; then
  fail "only the 'version' install type is supported (got: ${ASDF_INSTALL_TYPE})"
fi

readonly version="${ASDF_INSTALL_VERSION}"
readonly download_path="${ASDF_DOWNLOAD_PATH}"

mkdir -p "${download_path}"

url="$(release_url "${version}")"

echo "asdf-${TOOL_NAME}: downloading ${url}..."
if ! curl -fsSL -o "${download_path}/${BIN_NAME}" "${url}"; then
  fail "could not download ${url} — verify the version exists at ${GH_REPO}/releases and that an asset matches the expected platform"
fi

echo "asdf-${TOOL_NAME}: saved to ${download_path}/${BIN_NAME}"
